#!/usr/bin/env bash
set -eou pipefail

export PATH="$(fish --login -c 'string join : $PATH')"

systemctl --user import-environment \
	DISPLAY							\
	WAYLAND_DISPLAY					\
	PATH							\
	DBUS_SESSION_BUS_ADDRESS		\
	XDG_SEAT						\
	XDG_SESSION_CLASS				\
	XDG_SESSION_ID					\
	XDG_SESSION_TYPE				\
	XDG_VTNR						\
	2>/dev/null || true

systemctl --user reset-failed 2>/dev/null || true

systemctl --user start --wait hyprland.service

# ── Logout cleanup ─────────────────────────────────────────────────────────
# Tl;dr: On an explicit logout, hyprland.service is fully inactive with no
# pending jobs by the time --wait returns — Hyprland exited and nothing is
# queueing it back up. Cleanup your extra set env's in here.
#
# On a service restart (systemctl --user restart hyprland.service), systemd
# enqueues the new start job atomically as part of the restart job chain
# *before* the stop completes, so the job is already in the queue (and the
# unit may already be activating).
#
# On logout: --wait returns here and we proceed to tear down every
# env var this session imported so the next login starts from
# a clean slate in the systemd user manager.
#
# List mirrors hyprland-session-ready (import-environment block) plus
# the base session vars imported above, plus any hl.env() vars that
# dbus-update-activation-environment --systemd --all propagated.
# Keep this list in sync with environment_variables.lua and
# hyprland-session-ready whenever you add new hl.env() entries.
systemctl --user unset-environment		\
	DISPLAY								\
	WAYLAND_DISPLAY						\
	PATH								\
	XDG_BACKEND							\
	XDG_SEAT							\
	XDG_SESSION_CLASS					\
	XDG_SESSION_ID						\
	XDG_SESSION_TYPE					\
	XDG_VTNR							\
	HYPRLAND_CMD						\
	XCURSOR_SIZE						\
	HYPRCURSOR_SIZE						\
	XCURSOR_THEME						\
	QT_QPA_PLATFORM						\
	QT_QPA_PLATFORMTHEME				\
	XDG_MENU_PREFIX						\
	GTK_THEME							\
	GTK_USE_PORTAL						\
	XDG_CURRENT_DESKTOP					\
	XDG_SESSION_DESKTOP					\
	2>/dev/null || true
# ── End logout cleanup ──────────────────────────────────────────────────────

systemctl --user stop				\
	--job-mode=replace-irreversibly	\
	hyprland-session.target			\
	graphical-session.target		\
	graphical-session-pre.target	\
	2>/dev/null || true
